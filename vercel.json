{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "devCommand": "cd frontend && npm run dev",
  "installCommand": "cd frontend && npm install",
  "framework": "vite",
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap-carriers.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.my-bus.eu"
        }
      ],
      "destination": "https://my-bus.eu/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { 
      "source": "/api/:path*", 
      "destination": "https://mybus-backend-aygc.onrender.com/:path*" 
    },
    { 
      "source": "/sitemap-carriers.xml", 
      "destination": "https://mybus-backend-aygc.onrender.com/sitemap-carriers.xml" 
    },
    { 
      "source": "/(.*)", 
      "destination": "/" 
    }
  ]
}
